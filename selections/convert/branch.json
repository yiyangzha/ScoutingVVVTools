            { "name": "SelectedLepton_eta", "type": "F", "collection": "lep", "slots": 3, "formula": "eta(self)", "onlyMC": false },
            { "name": "SelectedLepton_phi", "type": "F", "collection": "lep", "slots": 3, "formula": "phi(self)", "onlyMC": false },
            { "name": "SelectedLepton_ecalIso", "type": "F", "collection": "lep", "slots": 3, "formula": "first_valid(ScoutingElectron_ecalIso, ScoutingMuonVtx_ecalIso, ScoutingMuonNoVtx_ecalIso)", "onlyMC": false },
            { "name": "SelectedLepton_hcalIso", "type": "F", "collection": "lep", "slots": 3, "formula": "first_valid(ScoutingElectron_hcalIso, ScoutingMuonVtx_hcalIso, ScoutingMuonNoVtx_hcalIso)", "onlyMC": false }
          ],
          "extrema": [
